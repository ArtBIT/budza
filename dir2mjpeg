#!/bin/bash

# exit on error, catch unset vars. Standard hygiene.
set -euo pipefail

SOURCE_DIR="${1:-.}"
QUALITY="${2:-7}"
FPS="${3:-24}"
SIZE="${4:-240}"

[[ -d "$SOURCE_DIR" ]] || { echo "Not a directory: $SOURCE_DIR" >&2; exit 1; }

# Make sure PNGs actually exist before invoking ffmpeg
shopt -s nullglob
pngs=("$SOURCE_DIR"/[0-9][0-9][0-9][0-9].png)
(( ${#pngs[@]} > 0 )) || { echo "No NNNN.png frames in $SOURCE_DIR" >&2; exit 1; }

DIRNAME="$(basename "$SOURCE_DIR")"
OUTPUT_FILE="${SOURCE_DIR%/}/${DIRNAME}.avi"
OUTPUT_FILE="${DIRNAME%/}.avi"

ffmpeg -y -framerate "$FPS" -i "${SOURCE_DIR%/}/%04d.png" \
  -c:v mjpeg -q:v "$QUALITY" -pix_fmt yuvj420p \
  -vf "scale=${SIZE}:${SIZE}:flags=lanczos" \
  -an "$OUTPUT_FILE"

printf "%s → %s\n" "$SOURCE_DIR" "$(du -h "$OUTPUT_FILE" | cut -f1)"
